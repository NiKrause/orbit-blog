{
  "name": "le-space-blog",
  "version": "0.4.15",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "files": [
    "dist",
    "src/lib"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "peerDependencies": {
    "svelte": "^4.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --mode lib",
    "preview": "vite preview",
    "relay": "DEBUG=le-space:*,libp2p:* orbitdb-relay",
    "relay:test": "DEBUG=libp2p:gossipsub,libp2p:relay:*,le-space:*,-le-space:relay:error orbitdb-relay --test",
    "relay:log": "DEBUG=libp2p:relay:* orbitdb-relay --test",
    "relay:sync-only": "ENABLE_GENERAL_LOGS=false ENABLE_SYNC_LOGS=true ENABLE_SYNC_STATS=true orbitdb-relay",
    "relay:quiet": "ENABLE_GENERAL_LOGS=false ENABLE_SYNC_LOGS=false ENABLE_SYNC_STATS=false orbitdb-relay",
    "relay:verbose": "ENABLE_GENERAL_LOGS=true ENABLE_SYNC_LOGS=true ENABLE_SYNC_STATS=true LOG_LEVEL_CONNECTION=true LOG_LEVEL_PEER=true LOG_LEVEL_DATABASE=true orbitdb-relay",
    "test": "mocha --config .mocharc.cjs test/orbitdb*.test.js && TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS='--loader ts-node/esm' TS_NODE_PROJECT=./tsconfig.test.json mocha --config .mocharc.cjs test/aiHttpTransport.test.ts test/aiCredentialCrypto.test.ts test/postFormAiI18n.test.ts test/aiModelRegistry.test.ts test/aiRemoteCapabilities.test.ts test/maskApiKey.test.ts test/aiInputSchema.test.ts test/aiJobErrors.test.ts test/buildSubmitJobInput.test.ts test/aiJobLifecycle.test.ts test/aiRunDocument.test.ts test/aiFetchResultParse.test.ts test/aiOutputTextMerge.test.ts test/fetchAiHttpTransport.test.ts test/mediaIngest.test.ts test/postUtilsVideo.test.ts test/relayPinStatus.test.ts",
    "test:e2e": "node scripts/run-e2e-specs.mjs",
    "test:e2e:ai-relay": "playwright test tests/AiRelayPinning.spec.ts",
    "test:e2e:ai-relay:remote": "PLAYWRIGHT_RELAY_MODE=remote playwright test tests/AiRelayPinning.spec.ts",
    "test:e2e:post-relay": "playwright test tests/PostsRelayReplication.spec.ts",
    "test:e2e:post-relay:remote": "PLAYWRIGHT_RELAY_MODE=remote playwright test tests/PostsRelayReplication.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "mocha --config .mocharc.cjs --watch",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.11",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@tsconfig/svelte": "^5.0.4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/hdkey": "^2.1.0",
    "@types/luxon": "^3.6.2",
    "@types/mocha": "^10.0.10",
    "autoprefixer": "^10.4.21",
    "buffer": "^6.0.3",
    "chai": "5.1.2",
    "mocha": "11.1.0",
    "node-fetch": "4.0.0-beta.4",
    "path-browserify": "^1.0.1",
    "postcss": "^8.5.3",
    "safe-buffer": "^5.2.1",
    "svelte": "5.28.2",
    "svelte-check": "^4.1.6",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",

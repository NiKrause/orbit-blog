    "dompurify": "^3.2.5",
    "dotenv": "^16.5.0",
    "esm-env": "^1.2.2",
    "hdkey": "^2.1.0",
    "helia": "^7.0.5",
    "html2pdf.js": "^0.10.3",
    "interface-blockstore": "^7.0.1",
    "interface-datastore": "^10.0.1",
    "key-did-provider-ed25519": "^4.0.2",
    "key-did-resolver": "^4.0.0",
    "libp2p": "^3.3.4",
    "luxon": "^3.6.1",
    "marked": "^12.0.2",
